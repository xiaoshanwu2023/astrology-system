[Unit]
Description=Astrology System Flask App
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/astrology-system
Environment="PATH=/var/www/astrology-system/venv/bin"
Environment="SECRET_KEY=change-this-to-a-random-secret-key"
Environment="FLASK_ENV=production"
ExecStart=/var/www/astrology-system/venv/bin/gunicorn -w 4 -b 127.0.0.1:8000 tencent_lighthouse:application
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
